@using System.Text.Json
@using ChefKnifeStudios.TransitJazz.Client.Core.Services
@using ChefKnifeStudios.TransitJazz.Shared
@using Microsoft.Extensions.Logging

@page "/signalr"
@inject ISignalRNotificationService NotificationService
@inject NavigationManager NavigationManager
@inject ILogger<SignalRTest> Logger

<h3>SignalR Test</h3>

<p>
    Connection status: <b>@connectionStatus</b>
</p>

<ul>
    @foreach (var msg in messages)
    {
        <li>@msg</li>
    }
</ul>

@code {
    private string connectionStatus = "Disconnected";
    private bool isConnected = false;
    private readonly List<string> messages = new();

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("SignalRTest: OnInitializedAsync started");
        try
        {
            await NotificationService.InitAsync();
            connectionStatus = "Connected";
            isConnected = true;
            Logger.LogInformation("SignalRTest: Connected to SignalR hub");

            NotificationService.NotificationReceived += async (batch) =>
            {
                Logger.LogDebug("SignalRTest: Batch received — {Count} events", batch.Count);
                await InvokeAsync(() =>
                {
                    Logger.LogInformation("Received batch of {count} events from SignalRNotificationService", batch.Count);
                    foreach (var notification in batch)
                    {
                        messages.Add($"{notification.EventType}: {notification.Payload}");
                        
                        var flattened = JsonFlattener.Flatten(notification.Payload);

                        // Debug: Check if the dictionary actually has items
                        Console.WriteLine($"Flattened Count: {flattened.Count}");

                        foreach (var kvp in flattened)
                        {
                            Console.WriteLine($"{kvp.Key}: {kvp.Value}");
                        }

                        // Final output
                        Console.WriteLine(JsonSerializer.Serialize(flattened, new JsonSerializerOptions { WriteIndented = true }));
                    }
                    StateHasChanged();
                });
            };
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SignalRTest: Failed to connect to SignalR hub");
            connectionStatus = $"Error: {ex.Message}";
        }
        Logger.LogInformation("SignalRTest: OnInitializedAsync complete");
    }
}