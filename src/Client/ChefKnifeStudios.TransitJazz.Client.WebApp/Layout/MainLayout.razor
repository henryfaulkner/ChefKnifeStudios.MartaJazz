@inherits LayoutComponentBase
@implements IDisposable
@inject IEventNotificationService EventNotificationService
@using ChefKnifeStudios.TransitJazz.Client.Shared.EventArgs
@using ChefKnifeStudios.TransitJazz.Client.Shared.Constants
@using ChefKnifeStudios.TransitJazz.Client.Core.Services

<MatThemeProvider Theme="@_currentTheme">
    @Body
    <MatToastContainer />
</MatThemeProvider>

@code {
    private MatTheme _currentTheme = LightTheme;
    private static readonly MatTheme LightTheme = new MatTheme
    {
        Primary = ColorConstants.Light.Primary,
        Secondary = ColorConstants.Light.Secondary,
        Surface = ColorConstants.Light.Surface,
        OnPrimary = ColorConstants.Light.OnPrimary,
        OnSecondary = ColorConstants.Light.OnSecondary,
        OnSurface = ColorConstants.Light.OnSurface
    };

    private static readonly MatTheme DarkTheme = new MatTheme
    {
        Primary = ColorConstants.Dark.Primary,
        Secondary = ColorConstants.Dark.Secondary,
        Surface = ColorConstants.Dark.Surface,
        OnPrimary = ColorConstants.Dark.OnPrimary,
        OnSecondary = ColorConstants.Dark.OnSecondary,
        OnSurface = ColorConstants.Dark.OnSurface
    };

    protected override void OnInitialized()
    {
        EventNotificationService.EventReceived += HandleThemeChange;
    }

    private void HandleThemeChange(object sender, IEventArgs e)
    {
        if (e is ThemeChangedEventArgs themeArgs)
        {
            _currentTheme = themeArgs.IsDarkMode ? DarkTheme : LightTheme;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        EventNotificationService.EventReceived -= HandleThemeChange;
    }
}
