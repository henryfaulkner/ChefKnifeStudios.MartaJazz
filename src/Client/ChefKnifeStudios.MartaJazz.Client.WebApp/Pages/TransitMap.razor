@page "/transit-map"
@using ChefKnifeStudios.MartaJazz.Client.Shared.Components

<div class="transit-map-container" @onclick="OnPageClickedAsync">
    <div class="connection-status connection-status--@_connectionCssClass">
        @_connectionLabel
    </div>
    @if (!_audioUnlocked)
    {
        <div class="audio-hint" style="position:absolute;top:12px;left:50%;transform:translateX(-50%);z-index:1000;background:rgba(0,0,0,0.65);color:#fff;padding:8px 16px;border-radius:6px;pointer-events:none;font-size:14px;">
            Click anywhere to enable audio
        </div>
    }
    <Map CameraOptions="DefaultCameraOptions"
        OnMapReady="OnMapReadyAsync"
        OnMapBodyClicked="OnMapBodyClickedAsync"
        OnBusMarkerClicked="OnVehicleMarkerClickedAsync"
    />
</div>
