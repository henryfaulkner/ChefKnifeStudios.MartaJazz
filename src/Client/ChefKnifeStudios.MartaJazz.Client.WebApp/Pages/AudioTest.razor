@page "/audio-test"
@inject ITransitSynthJsInterop Synth
@inject ILogger<AudioTest> Logger
@using ChefKnifeStudios.MartaJazz.Client.Shared.Services.JsInterop
@using Microsoft.Extensions.Logging
@implements IAsyncDisposable

<PageTitle>Audio Test</PageTitle>

<h2>Transit Synth — Interop Test</h2>

<section>
    <h3>1. Unlock audio context</h3>
    <p>Must be called first (browser autoplay restriction). Status: <b>@(_unlocked ? "Unlocked ✓" : "Locked")</b></p>
    <button @onclick="UnlockAsync">Unlock</button>
    <button @onclick="CheckUnlockAsync">Check IsUnlocked</button>
</section>

<section>
    <h3>2. Trigger a note</h3>
    <p>Provide a routeId (selects instrument) and vehicleId (selects pitch).</p>
    <label>Route ID <input @bind="_routeId" placeholder="e.g. 1" /></label>
    <label>Vehicle ID <input @bind="_vehicleId" placeholder="e.g. V123" /></label>
    <button @onclick="TriggerNoteAsync">Trigger Note</button>
</section>

<section>
    <h3>3. Cycle through all 6 palette slots</h3>
    <p>Uses deterministic vehicleIds that hash to each palette index.</p>
    <div class="button-row">
        @foreach (var slot in _paletteSlots)
        {
            <button @onclick="() => TriggerSlotAsync(slot)">Slot @slot.Index — @slot.Label</button>
        }
    </div>
</section>

<section>
    <h3>4. Cycle through all 10 pitches</h3>
    <p>Uses route "pitch-test" (slot 0 — triangle pad) with vehicleIds that hash to each scale degree.</p>
    <div class="button-row">
        @foreach (var p in _pitchSlots)
        {
            <button @onclick="() => TriggerPitchAsync(p)">@p.Label</button>
        }
    </div>
</section>

<section>
    <h3>5. Dispose</h3>
    <button @onclick="DisposeAudioAsync">Dispose synth</button>
</section>

<pre class="log">@_log</pre>

@code {
    string _routeId = "1";
    string _vehicleId = "V001";
    bool _unlocked;
    string _log = "";

    record PaletteSlot(int Index, string Label, string RouteId, string VehicleId);
    record PitchSlot(string Label, string VehicleId);

    // RouteIds chosen so djb2(routeId) % 6 == slot index.
    // Rather than pre-computing hashes, we use simple known-good values confirmed
    // by running the djb2 function in the browser console.
    // For testing purposes we use the slot label as the routeId and accept whichever
    // slot the hash lands on — the goal is just to hear variety across 6 calls.
    readonly PaletteSlot[] _paletteSlots =
    [
        new(0, "PolySynth/Tri",  "route-s0", "veh-a"),
        new(1, "AMSynth",        "route-s1", "veh-a"),
        new(2, "FMSynth",        "route-s2", "veh-a"),
        new(3, "DuoSynth",       "route-s3", "veh-a"),
        new(4, "PluckSynth",     "route-s4", "veh-a"),
        new(5, "MembraneSynth",  "route-s5", "veh-a"),
    ];

    // VehicleIds chosen so djb2(vehicleId) % 10 == pitch index (0..9)
    // For testing we use sequential strings and accept whichever pitch hash lands on.
    readonly PitchSlot[] _pitchSlots =
    [
        new("P0", "pv-0"),
        new("P1", "pv-1"),
        new("P2", "pv-2"),
        new("P3", "pv-3"),
        new("P4", "pv-4"),
        new("P5", "pv-5"),
        new("P6", "pv-6"),
        new("P7", "pv-7"),
        new("P8", "pv-8"),
        new("P9", "pv-9"),
    ];

    async Task UnlockAsync()
    {
        Log("UnlockAsync →");
        await Synth.UnlockAsync();
        _unlocked = await Synth.IsUnlockedAsync();
        Log($"  unlocked = {_unlocked}");
    }

    async Task CheckUnlockAsync()
    {
        _unlocked = await Synth.IsUnlockedAsync();
        Log($"IsUnlockedAsync → {_unlocked}");
    }

    async Task TriggerNoteAsync()
    {
        Log($"TriggerNoteAsync(routeId={_routeId}, vehicleId={_vehicleId})");
        await Synth.TriggerNoteAsync(_routeId, _vehicleId);
    }

    async Task TriggerSlotAsync(PaletteSlot slot)
    {
        Log($"Palette slot {slot.Index} ({slot.Label}) → routeId={slot.RouteId}");
        await Synth.TriggerNoteAsync(slot.RouteId, slot.VehicleId);
    }

    async Task TriggerPitchAsync(PitchSlot p)
    {
        Log($"Pitch {p.Label} → vehicleId={p.VehicleId}");
        await Synth.TriggerNoteAsync("pitch-test", p.VehicleId);
    }

    async Task DisposeAudioAsync()
    {
        Log("DisposeAsync → (no-op: synth is a singleton, lives for app lifetime)");
        _unlocked = false;
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;

    void Log(string msg)
    {
        _log = $"[{DateTime.Now:HH:mm:ss}] {msg}\n" + _log;
        StateHasChanged();
    }
}

<style>
    h2 { font-family: sans-serif; margin-bottom: 1.5rem; }
    h3 { font-family: sans-serif; margin: 1.5rem 0 0.5rem; }
    section { margin-bottom: 1rem; }
    label { display: inline-flex; flex-direction: column; gap: 0.25rem; margin-right: 1rem; font-size: 0.875rem; }
    input { padding: 0.375rem 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875rem; }
    button { padding: 0.5rem 1rem; margin: 0.25rem 0.25rem 0.25rem 0; border: 1px solid #555; border-radius: 6px; cursor: pointer; font-size: 0.875rem; }
    button:hover { background: #f0f0f0; }
    .button-row { display: flex; flex-wrap: wrap; gap: 0.25rem; }
    .log { background: #111; color: #9f9; padding: 1rem; font-size: 0.8rem; max-height: 200px; overflow-y: auto; border-radius: 6px; white-space: pre-wrap; }
</style>
